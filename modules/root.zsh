###########################################################################
# modules/root.zsh
#
# Detección de usuario root.
###########################################################################

typeset -g __ZSH_IS_ROOT=0

###########################################################################
# root::update()
###########################################################################

root::update() {

    if [[ "$EUID" -eq 0 ]]; then
        __ZSH_IS_ROOT=1
    else
        __ZSH_IS_ROOT=0
    fi
}

###########################################################################
# Init
###########################################################################

root::update